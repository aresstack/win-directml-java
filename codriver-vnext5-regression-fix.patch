@@ -0,0 +1,134 @@
+/* ==========================================================================
+   CoDriver original-reference correction pass.
+
+   This file intentionally loads last. It repairs the visual regressions from
+   the experimental vnext passes while keeping the fixes scoped to the CoDriver
+   theme. Default light/dark/system rendering is not changed.
+   ========================================================================== */
+
+html[data-theme="codriver"] {
+    /* GitHub/VS Code chat canvas: neutral, no permanent blue wash. */
+    --codriver-canvas: #0d1117;
+    --codriver-chat-surface: #0d1117;
+
+    /* Keep the composer as the grey input panel that was closer to the target. */
+    --codriver-composer-bg: #44474e;
+    --codriver-composer-bg-hover: #474a51;
+    --codriver-composer-border: rgba(88, 166, 255, 0.56);
+    --codriver-composer-border-hover: rgba(88, 166, 255, 0.78);
+    --codriver-composer-shadow: rgba(88, 166, 255, 0.18);
+}
+
+html[data-theme="codriver"] body,
+html[data-theme="codriver"] #app,
+html[data-theme="codriver"] .messages-shell,
+html[data-theme="codriver"] .messages-container,
+html[data-theme="codriver"] .message.assistant .message-content {
+    background: var(--codriver-chat-surface) !important;
+}
+
+/* Composer: restore the grey panel and the stronger blue outline, but remove
+   the conic-gradient working border that JCEF rendered as a huge diagonal arc. */
+html[data-theme="codriver"] .chat-input-box {
+    background: var(--codriver-composer-bg) !important;
+    border: 1px solid var(--codriver-composer-border) !important;
+    box-shadow:
+        0 0 0 1px var(--codriver-composer-shadow),
+        0 10px 28px rgba(1, 4, 9, 0.26) !important;
+}
+
+html[data-theme="codriver"] .chat-input-box:hover,
+html[data-theme="codriver"] .chat-input-box:focus-within,
+html[data-theme="codriver"] .chat-input-box.is-resizing,
+html[data-theme="codriver"] .chat-input-box.is-loading {
+    background: var(--codriver-composer-bg-hover) !important;
+    border-color: var(--codriver-composer-border-hover) !important;
+    box-shadow:
+        0 0 0 1px rgba(88, 166, 255, 0.28),
+        0 12px 30px rgba(1, 4, 9, 0.30) !important;
+}
+
+html[data-theme="codriver"] .chat-input-box::before,
+html[data-theme="codriver"] .chat-input-box::after,
+html[data-theme="codriver"] .chat-input-box.is-loading::before,
+html[data-theme="codriver"] .chat-input-box.is-loading::after {
+    content: none !important;
+    display: none !important;
+    opacity: 0 !important;
+    animation: none !important;
+    background: none !important;
+    -webkit-mask: none !important;
+    mask: none !important;
+}
+
+html[data-theme="codriver"] .input-editable-wrapper,
+html[data-theme="codriver"] .input-editable,
+html[data-theme="codriver"] .input-footer,
+html[data-theme="codriver"] .input-tools-left,
+html[data-theme="codriver"] .input-actions {
+    background: transparent !important;
+}
+
+/* Tool status: VS Code/Copilot-style quiet inline icons, not green/yellow balls. */
+html[data-theme="codriver"] .tool-status-indicator {
+    width: 16px !important;
+    height: 16px !important;
+    min-width: 16px !important;
+    border: 0 !important;
+    border-radius: 0 !important;
+    background: transparent !important;
+    display: inline-flex !important;
+    align-items: center !important;
+    justify-content: center !important;
+    box-shadow: none !important;
+}
+
+html[data-theme="codriver"] .tool-status-indicator::before,
+html[data-theme="codriver"] .tool-status-indicator::after {
+    content: none !important;
+}
+
+html[data-theme="codriver"] .tool-status-indicator.completed {
+    color: var(--codriver-fg-muted, #8b949e) !important;
+}
+
+html[data-theme="codriver"] .tool-status-indicator.error {
+    color: var(--codriver-danger, #f85149) !important;
+}
+
+html[data-theme="codriver"] .tool-status-indicator.pending {
+    color: var(--codriver-fg-muted, #8b949e) !important;
+    animation: none !important;
+}
+
+html[data-theme="codriver"] .tool-status-indicator.pending .codriver-tool-status-icon {
+    animation: codriver-quiet-spin 1.1s linear infinite;
+}
+
+html[data-theme="codriver"] .codriver-tool-status-icon {
+    display: block;
+    color: currentColor;
+}
+
+@keyframes codriver-quiet-spin {
+    to { transform: rotate(360deg); }
+}
+
+/* Keep lower toolbar icons muted unless the user interacts with them. */
+html[data-theme="codriver"] .input-footer .codriver-icon,
+html[data-theme="codriver"] .input-footer .codicon,
+html[data-theme="codriver"] .input-tools-left .codriver-icon,
+html[data-theme="codriver"] .input-tools-left .codicon,
+html[data-theme="codriver"] .input-actions .codriver-icon,
+html[data-theme="codriver"] .input-actions .codicon {
+    color: var(--codriver-fg-subtle, #6e7681) !important;
+}
+
+html[data-theme="codriver"] .input-footer button:hover .codriver-icon,
+html[data-theme="codriver"] .input-footer button:hover .codicon,
+html[data-theme="codriver"] .input-tools-left button:hover .codriver-icon,
+html[data-theme="codriver"] .input-tools-left button:hover .codicon,
+html[data-theme="codriver"] .input-actions button:hover .codriver-icon,
+html[data-theme="codriver"] .input-actions button:hover .codicon {
+    color: var(--codriver-link, #58a6ff) !important;
+}
